# ── Techlogic Productivity System — backend env (copy to backend/.env) ───────

# Local Postgres — create the database first (e.g. CREATE DATABASE techlogic_productivity;)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/techlogic_productivity"

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Public base URL the agent/installer must reach (this host's LAN IP in a network
# pilot, or the deployed API URL in production). Used to bake --server into the
# per-company installer. Falls back to the request host if unset.
# MON_PUBLIC_SERVER_URL=http://192.168.0.30:3001

# ── Portal (dashboard) auth — REQUIRED ───────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
PORTAL_JWT_SECRET="change-me-to-a-long-random-string"
PORTAL_JWT_TTL="12h"

# First provider-admin login, created by prisma/portal-bootstrap.js.
PORTAL_PROVIDER_EMAIL="admin@techlogicservices.co.uk"
PORTAL_PROVIDER_PASSWORD="ChangeMe-Provider-2026!"

# Secret used to encrypt company enrolment keys at rest so they can be re-displayed.
# MUST stay stable across restarts (else keys can't be decrypted). Defaults to
# PORTAL_JWT_SECRET if unset.
# ENROLLMENT_KEY_SECRET="another-long-random-string"

# ── Optional tuning (sensible defaults in code) ──────────────────────────────
# MON_ROLLUP_INTERVAL_MIN=5
# MON_SAMPLE_INTERVAL_SEC=5
# MON_UPLOAD_INTERVAL_SEC=60
# MON_IDLE_THRESHOLD_SEC=300
# MON_ROLLUP_WINDOW_DAYS=7
# MON_RETENTION_DAYS=90
# Where the backend reads the prebuilt agent exe for /agent-download:
# AGENT_EXE_PATH=../agent-windows/publish/ProductivityAgent.exe

# Legacy single global enrolment secret (the product uses per-company keys; leave blank).
MONITORING_ENROLLMENT_SECRET=""
